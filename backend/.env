# .env file
# These are secrets - NEVER commit this to GitHub!

NODE_ENV=development
PORT=3001

# Database connection
DB_USER=nourine
DB_HOST=localhost
DB_NAME=educational_app
DB_PASSWORD=
DB_PORT=5432

# JWT Secret (make up a random string)
JWT_SECRET=your_random_jwt_secret_key_change_this_in_production_12345
JWT_EXPIRE=24h

# Cloudinary (we'll set up later)
CLOUDINARY_API_KEY=your_key_here
CLOUDINARY_API_SECRET=your_secret_here
CLOUDINARY_CLOUD_NAME=your_name_here